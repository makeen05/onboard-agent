# .env.example
#
# Copy this file to ".env" and fill in real values.
# .env is gitignored so secrets never get committed to source control.
# python-dotenv reads .env automatically when your app starts.
#
# These values are for running the API/worker OUTSIDE Docker (e.g. directly
# with "python -m api.worker" on your machine). Inside Docker, the environment
# variables are set in docker-compose.yml instead.

TEMPORAL_HOST=localhost:7233
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/onboard

# These will be needed in later milestones:
# OPENAI_API_KEY=sk-...
# GITHUB_TOKEN=ghp_...
